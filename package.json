{
  "name": "zabware",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "^22.17.1"
  },
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register ./app.ts",
    "repl": "ts-node -r tsconfig-paths/register",
    "test": "ts-mocha --paths -p ./tsconfig.json server/**/*.spec.ts",
    "coverage": "nyc npm run test",
    "dev": "ts-node-dev --watch -r tsconfig-paths/register ./app.ts",
    "lint": "git diff --cached --name-only --diff-filter=d | grep '.ts$' | xargs eslint",
    "lint:fix": "npm run lint -- --fix",
    "tsc": "tsc",
    "tsc-w": "tsc -w",
    "stop": "kill -9 $(lsof -t -i:3011)",
    "script:backfill-task-occurrences": "ts-node -r tsconfig-paths/register ./server/scripts/backfill-task-occurrences.ts",
    "script:remove-invalid-task-occurrences": "ts-node -r tsconfig-paths/register ./server/scripts/remove-invalid-task-occurrences.ts",
    "script:backfill-time-taken": "ts-node -r tsconfig-paths/register ./server/scripts/backfill-time-taken.ts",
    "script:fix-future-occurrence-dates": "ts-node -r tsconfig-paths/register ./server/scripts/fix-future-occurrence-dates.ts"
  },
  "dependencies": {
    "@fattureincloud/fattureincloud-js-sdk": "^2.0.25",
    "@hapi/joi": "^17.1.1",
    "@influxdata/influxdb-client": "^1.33.2",
    "@sendgrid/mail": "^8.1.1",
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "dotenv-expand": "^10.0.0",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "html-pdf": "^3.0.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mariadb": "^3.2.3",
    "moment-timezone": "^0.5.46",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.7.0",
    "node-cron": "^3.0.3",
    "node-pushnotifications": "^3.0.0",
    "nodemailer": "^7.0.5",
    "otp-generator": "^4.0.1",
    "sequelize": "^6.35.2",
    "ts-node-dev": "^2.0.0",
    "twilio": "^5.0.0",
    "typescript": "^5.9.3",
    "xlsx": "^0.18.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged && npm run lint:fix"
    }
  },
  "lint-staged": {
    "./src/*.{js,jsx,ts,tsx}": [
      "npx prettier --write",
      "eslint server/**/*.js --fix-dry-run"
    ]
  },
  "settings": {
    "import/resolver": {
      "typescript": {}
    }
  },
  "devDependencies": {
    "tsconfig-paths": "^4.2.0"
  }
}
